<clickhouse>
    <!-- ============================================================
         old-shard2  –  OLD cluster, shard 2
         ============================================================ -->

    <logger>
        <level>information</level>
        <console>true</console>
    </logger>

    <listen_host>0.0.0.0</listen_host>

    <users>
        <default>
            <password></password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
        </default>
    </users>

    <remote_servers>
        <epm_cluster>
            <shard>
                <weight>1</weight>
                <internal_replication>false</internal_replication>
                <replica>
                    <host>old-shard1</host>
                    <port>9000</port>
                </replica>
            </shard>
            <shard>
                <weight>1</weight>
                <internal_replication>false</internal_replication>
                <replica>
                    <host>old-shard2</host>
                    <port>9000</port>
                </replica>
            </shard>
        </epm_cluster>
    </remote_servers>

    <macros>
        <cluster>epm_cluster</cluster>
        <shard>02</shard>
        <replica>old-shard2</replica>
    </macros>
</clickhouse>
