<clickhouse>
    <!-- new-s1-r1  –  NEW cluster, shard 1 replica 1, TLS, ReplicatedMergeTree -->

    <logger><level>information</level><console>true</console></logger>
    <listen_host>0.0.0.0</listen_host>

    <tcp_port_secure>9440</tcp_port_secure>
    <tcp_port>9000</tcp_port>

    <openSSL>
        <server>
            <certificateFile>/etc/clickhouse-server/tls/new-s1-r1.crt</certificateFile>
            <privateKeyFile>/etc/clickhouse-server/tls/new-s1-r1.key</privateKeyFile>
            <dhParamsFile>/etc/clickhouse-server/tls/dhparam.pem</dhParamsFile>
            <caConfig>/etc/clickhouse-server/tls/ca.crt</caConfig>
            <verificationMode>none</verificationMode>
            <loadDefaultCAFile>false</loadDefaultCAFile>
            <cacheSessions>true</cacheSessions>
        </server>
        <client>
            <caConfig>/etc/clickhouse-server/tls/ca.crt</caConfig>
            <verificationMode>none</verificationMode>
            <loadDefaultCAFile>false</loadDefaultCAFile>
        </client>
    </openSSL>

    <users>
        <default>
            <password></password>
            <networks><ip>::/0</ip></networks>
            <profile>default</profile>
            <quota>default</quota>
        </default>
    </users>

    <zookeeper>
        <node>
            <host>zookeeper2</host>
            <port>2181</port>
        </node>
    </zookeeper>

    <remote_servers>
        <!-- New cluster: 2 shards × 2 replicas -->
        <main>
            <shard>
                <weight>1</weight>
                <internal_replication>true</internal_replication>
                <replica>
                    <host>new-s1-r1</host>
                    <port>9440</port>
                    <secure>1</secure>
                </replica>
                <replica>
                    <host>new-s1-r2</host>
                    <port>9440</port>
                    <secure>1</secure>
                </replica>
            </shard>
            <shard>
                <weight>1</weight>
                <internal_replication>true</internal_replication>
                <replica>
                    <host>new-s2-r1</host>
                    <port>9440</port>
                    <secure>1</secure>
                </replica>
                <replica>
                    <host>new-s2-r2</host>
                    <port>9440</port>
                    <secure>1</secure>
                </replica>
            </shard>
        </main>
    </remote_servers>

    <macros>
        <cluster>main</cluster>
        <shard>01</shard>
        <replica>new-s1-r1</replica>
    </macros>
</clickhouse>
